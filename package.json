{
  "name": "h4kken",
  "version": "1.0.0",
  "description": "H4KKEN - 3D Online Fighting Game",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "dev": "concurrently \"bun --watch server.ts\" \"vite\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "bun dist/server.js",
    "fix": "bun x biome check --write . && tsc --noEmit && tsc -p tsconfig.server.json --noEmit && bun x knip",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "ci": "bun x biome ci . && bun test && tsc --noEmit && tsc -p tsconfig.server.json --noEmit && bun x knip",
    "prepare": "husky",
    "build:character": "bun scripts/build-character.ts"
  },
  "dependencies": {
    "@babylonjs/core": "^9.3.1",
    "@babylonjs/loaders": "^9.3.1",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@babylonjs/serializers": "^9.3.1",
    "@biomejs/biome": "^2.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "knip": "^6.3.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  }
}
